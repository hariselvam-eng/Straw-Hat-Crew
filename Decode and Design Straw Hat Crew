<!-- FOOTER -->
<footer>
  <div class="footer-text">"The worst thing in the world is to try to sleep and not to."</div>
  <div class="footer-sub">— F. Scott Fitzgerald</div>
</footer>

<script>
  // ── CURSOR
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursor-ring');
  document.addEventListener('mousemove', e => {
    cursor.style.left = e.clientX - 6 + 'px';
    cursor.style.top = e.clientY - 6 + 'px';
    ring.style.left = e.clientX - 18 + 'px';
    ring.style.top = e.clientY - 18 + 'px';
  });

  // ── LIVE CLOCK
  function updateClock() {
    const now = new Date();
    let h = now.getHours();
    const m = String(now.getMinutes()).padStart(2,'0');
    const ampm = h >= 12 ? 'PM' : 'AM';
    h = h % 12 || 12;
    document.getElementById('live-clock').textContent = `${h}:${m} ${ampm}`;
  }
  updateClock();
  setInterval(updateClock, 1000);

  // ── HERO THOUGHT BUBBLES
  const phrases = [
    "can't sleep", "3 am again", "just close them",
    "stop thinking", "why am I awake", "walls are humming",
    "overthinking", "eyes burning", "breathe",
    "tomorrow...", "did I lock the door?", "just five minutes"
  ];
  let thoughtInterval = null;
  function spawnHeroThought() {
    if (document.body.classList.contains('morning')) return;
    const el = document.createElement('div');
    el.className = 'thought-bubble';
    el.textContent = phrases[Math.floor(Math.random() * phrases.length)];
    el.style.left = Math.random() * 80 + 10 + '%';
    el.style.top = Math.random() * 70 + 15 + '%';
    const dur = 4000 + Math.random() * 3000;
    el.style.animationDuration = dur + 'ms';
    document.getElementById('hero').appendChild(el);
    setTimeout(() => el.remove(), dur + 100);
  }
  thoughtInterval = setInterval(spawnHeroThought, 1800);

  // ── STATIC SECTION DRIFTING WORDS
  const staticWords = [
    "sleep", "rest", "peace", "quiet", "darkness", "still",
    "silence", "dreams", "exhausted", "tired", "void", "night"
  ];
  const staticContainer = document.getElementById('static-thoughts');
  function spawnStaticWord() {
    const el = document.createElement('div');
    el.className = 'static-word';
    el.textContent = staticWords[Math.floor(Math.random() * staticWords.length)];
    el.style.top = Math.random() * 90 + '%';
    el.style.fontSize = (1 + Math.random() * 3) + 'rem';
    const dur = 8000 + Math.random() * 10000;
    el.style.animationDuration = dur + 'ms';
    staticContainer.appendChild(el);
    setTimeout(() => el.remove(), dur);
  }
  for (let i = 0; i < 8; i++) setTimeout(spawnStaticWord, i * 800);
  setInterval(spawnStaticWord, 2000);

  // ── TIMELINE SCROLL REVEAL
  const tlItems = document.querySelectorAll('.tl-item');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) setTimeout(() => e.target.classList.add('visible'), 100);
    });
  }, { threshold: 0.2 });
  tlItems.forEach(el => obs.observe(el));

  // ══════════════════════════════════════════
  // ── AMBIENT SOUND ENGINE (Web Audio API)
  // ══════════════════════════════════════════
  let audioCtx = null;
  let soundNodes = {};
  let soundOn = false;

  function initAudio() {
    if (audioCtx) return;
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  }

  function createWhiteNoise(ctx) {
    const bufferSize = ctx.sampleRate * 4;
    const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
    const data = buffer.getChannelData(0);
    for (let i = 0; i < bufferSize; i++) data[i] = Math.random() * 2 - 1;
    const source = ctx.createBufferSource();
    source.buffer = buffer;
    source.loop = true;

    // filter to make it sound like ambient room hum
    const filter = ctx.createBiquadFilter();
    filter.type = 'lowpass';
    filter.frequency.value = 400;

    const gainNode = ctx.createGain();
    gainNode.gain.value = 0;

    source.connect(filter);
    filter.connect(gainNode);
    gainNode.connect(ctx.destination);
    source.start();
    return { source, gainNode };
  }

  function createClockTick(ctx) {
    const gainNode = ctx.createGain();
    gainNode.gain.value = 0;
    gainNode.connect(ctx.destination);

    let tickInterval = null;
    function tick() {
      if (!soundOn) return;
      // tick
      const osc = ctx.createOscillator();
      const g = ctx.createGain();
      osc.frequency.value = 1200;
      g.gain.setValueAtTime(0.08, ctx.currentTime);
      g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.04);
      osc.connect(g);
      g.connect(ctx.destination);
      osc.start();
      osc.stop(ctx.currentTime + 0.04);

      // tock after 0.5s
      setTimeout(() => {
        if (!soundOn) return;
        const osc2 = ctx.createOscillator();
        const g2 = ctx.createGain();
        osc2.frequency.value = 1000;
        g2.gain.setValueAtTime(0.06, ctx.currentTime);
        g2.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.04);
        osc2.connect(g2);
        g2.connect(ctx.destination);
        osc2.start();
        osc2.stop(ctx.currentTime + 0.04);
      }, 500);
    }

    return {
      start() { tickInterval = setInterval(tick, 1000); tick(); },
      stop() { clearInterval(tickInterval); tickInterval = null; },
      gainNode
    };
  }

  function startSound() {
    initAudio();
    if (audioCtx.state === 'suspended') audioCtx.resume();

    const noise = createWhiteNoise(audioCtx);
    noise.gainNode.gain.setTargetAtTime(0.08, audioCtx.currentTime, 1.5);

    const clock = createClockTick(audioCtx);
    clock.start();

    soundNodes = { noise, clock };
  }

  function stopSound() {
    if (!soundNodes.noise) return;
    soundNodes.noise.gainNode.gain.setTargetAtTime(0, audioCtx.currentTime, 0.8);
    soundNodes.clock.stop();
    setTimeout(() => {
      try { soundNodes.noise.source.stop(); } catch(e) {}
      soundNodes = {};
    }, 2000);
  }

  function toggleSound() {
    soundOn = !soundOn;
    const btn = document.getElementById('sound-btn');
    const icon = document.getElementById('sound-icon');
    const label = document.getElementById('sound-label');
    if (soundOn) {
      startSound();
      icon.textContent = '🔊';
      label.textContent = 'Sound On';
      btn.classList.add('active');
    } else {
      stopSound();
      icon.textContent = '🔇';
      label.textContent = 'Ambient Sound';
      btn.classList.remove('active');
    }
  }

  // ══════════════════════════════════════════
  // ── MORNING MODE
  // ══════════════════════════════════════════
  let isMorning = false;

  function playMorningSwell() {
    initAudio();
    if (audioCtx.state === 'suspended') audioCtx.resume();

    // Soft warm chord swell — a gentle major chord
    const freqs = [261.63, 329.63, 392.00, 523.25]; // C major
    freqs.forEach((freq, i) => {
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      const pan = audioCtx.createStereoPanner();

      osc.type = 'sine';
      osc.frequency.value = freq;
      pan.pan.value = (i - 1.5) * 0.3;

      gain.gain.setValueAtTime(0, audioCtx.currentTime);
      gain.gain.linearRampToValueAtTime(0.06, audioCtx.currentTime + 2 + i * 0.3);
      gain.gain.linearRampToValueAtTime(0.03, audioCtx.currentTime + 5);
      gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 8);

      osc.connect(gain);
      gain.connect(pan);
      pan.connect(audioCtx.destination);
      osc.start();
      osc.stop(audioCtx.currentTime + 8);
    });

    // Also fade night sounds if on
    if (soundOn && soundNodes.noise) {
      soundNodes.noise.gainNode.gain.setTargetAtTime(0.02, audioCtx.currentTime, 2);
      soundNodes.clock.stop();
    }
  }

  function playNightReturn() {
    if (soundOn && soundNodes.noise) {
      soundNodes.noise.gainNode.gain.setTargetAtTime(0.08, audioCtx.currentTime, 1.5);
      soundNodes.clock.start();
    }
  }

  function toggleMorning() {
    isMorning = !isMorning;
    document.body.classList.toggle('morning', isMorning);

    const icon = document.getElementById('morning-icon');
    const label = document.getElementById('morning-label');
    const btn = document.getElementById('morning-btn');

    if (isMorning) {
      icon.textContent = '☀️';
      label.textContent = 'Morning';
      btn.classList.add('active');
      playMorningSwell();

      // Remove jitter — morning is calm
      document.body.style.animation = 'none';
      document.querySelector('.grain').style.animationPlayState = 'paused';
    } else {
      icon.textContent = '🌙';
      label.textContent = 'Night Mode';
      btn.classList.remove('active');
      playNightReturn();

      document.body.style.animation = '';
      document.querySelector('.grain').style.animationPlayState = 'running';
    }
  }
</script>
</body>
</html>
